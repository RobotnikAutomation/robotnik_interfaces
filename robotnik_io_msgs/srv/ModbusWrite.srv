# Request structure to perform a Modbus "write" operation on a device.

# Modbus function code defining the type of write operation.
# Use values from ModbusFunctionCode.msg:
#   5  - Write Single Coil
#   6  - Write Single Holding Register
#   15 - Write Multiple Coils
#   16 - Write Multiple Holding Registers
uint8 function_code

# Starting address (zero-based) in the Modbus memory map to begin writing.
uint16 starting_address

# Values to be written to the device.
# For coils: each value should be 0 (OFF) or non-zero (ON).
# For registers: 16-bit unsigned integers.
uint16[] data

---

# Response structure returned after a Modbus write request.

# Indicates whether the write operation completed successfully.
bool success

# If the request failed (success == false), this field contains a
# human-readable explanation or Modbus exception reason.
string error_message

# Optional Modbus exception code (structured error info)
uint8 exception_code
